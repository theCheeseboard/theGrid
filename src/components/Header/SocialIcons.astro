---
import { Github } from 'simple-icons-astro'
---

<div class="social-icons">
    <a href="https://github.com/theCheeseboard/theGrid"><Github /></a>
</div>

<style>
    .social-icons {
        display: flex;
        gap: 8px;
    }

    .social-icons a {
        color: var(--foreground-color);
        opacity: 0.7;
    }

    .social-icons a:hover {
        opacity: 1;
    }
</style>